# --- NextAuth.js ---
# `openssl rand -base64 32` などで生成したランダム文字列
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 個人利用アプリのため、このメールアドレス以外はログインを拒否する(未設定なら誰でもログイン可)
ALLOWED_GOOGLE_EMAIL=

# --- Database (Supabase Postgres) ---
# Prisma Migrate用: Supabase > Project Settings > Database > Connection string > "Direct connection"
DIRECT_URL=
# アプリ実行時用: 同画面の "Session pooler" (port 6543)
DATABASE_URL=

# --- Supabase (Storage等で使用予定) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Maps JavaScript API ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Places API(サーバー側のみで使用。NEXT_PUBLIC_は付けない) ---
# 制限は「アプリケーションの制限: なし」+「APIの制限: Places API」を推奨
# (サーバーからのリクエストなのでHTTPリファラー制限は使えないため)
GOOGLE_PLACES_API_KEY=

# --- OpenAI (Step7以降: AI要約で使用予定) ---
OPENAI_API_KEY=
